# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# Production builds
/build
dist/
dist

# Environment files (comprehensive coverage)
*token.json*
*credentials.json*

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dump.rdb

# System files
.DS_Store
*.pem

# Python
__pycache__/
*pyc*
venv/
.venv/

# Development tools
chainlit.md
.chainlit
.ipynb_checkpoints/
.ac

# Deployment
.vercel

# Data and databases
agenthub/agents/youtube/db

# Migration artifacts (read-only profiler output)
.migration-artifacts/

# Archive files and large assets
**/*.zip
**/*.tar.gz
**/*.tar
**/*.tgz
*.pack
*.deb
*.dylib

# Build caches
.cache/

# Mobile development
android-sdk/

# Next.js SWC platform binaries (committed by package, not source-controlled)
node_modules/@next/swc-linux-arm64-gnu/next-swc.linux-arm64-gnu.node
node_modules/@next/swc-linux-arm64-musl/next-swc.linux-arm64-musl.node

# Environment files — real secrets are NEVER committed. Only the placeholder
# template (.env.example) is tracked so a fresh developer can copy it.
# The negation below MUST come after the broad ignore rules.
.env
.env.*
!.env.example

# Prisma generated client (produced by `prisma generate`, never hand-edited).
# Emitted at lib/generated/prisma (outside app/ so Next.js 16 Turbopack does
# not auto-promote the JS project to TypeScript). See docs/database-migration.md.
/lib/generated/prisma
