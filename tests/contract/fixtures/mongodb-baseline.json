{
  "inventory": [
    {"route":"auth","requests":["POST /api/auth/login invalid","POST /api/auth/login valid","GET /api/auth/verify public/authenticated"]},
    {"route":"stats","requests":["GET /api/stats (public/authenticated)"]},
    {"route":"upload","requests":["POST /api/upload (unauthenticated/authenticated)"]},
    {"route":"media","requests":["GET /api/media?page=1&limit=2","GET /api/media/:id (public/authenticated)","PUT /api/media/:id authenticated","DELETE /api/media/:id authenticated"]},
    {"route":"news","requests":["GET /api/news","GET /api/news?public=true&page=1&limit=2","GET /api/news/:id","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"announcements","requests":["GET /api/announcements","GET /api/announcements?public=true","GET /api/announcements/:id","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"services","requests":["GET /api/services","GET /api/services/:id","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"cases","requests":["GET /api/cases?page=1&limit=2","GET /api/cases?namaPihak=...","GET /api/cases/:id","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"users","requests":["GET /api/users (public/authenticated)","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"settings","requests":["GET /api/settings","PUT /api/settings authenticated"]},
    {"route":"pages","requests":["GET /api/pages","GET /api/pages/:id","GET /api/pages/slug/:published","GET /api/pages/slug/:draft (public/authenticated)","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"agenda","requests":["GET /api/agenda?public=true&page=1&limit=2","GET /api/agenda?dateFrom=...&dateTo=...","GET /api/agenda/:id","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"putusan","requests":["GET /api/putusan?public=true&page=1&limit=2","GET /api/putusan/:id","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"sidebar-widgets","requests":["GET /api/sidebar-widgets","GET /api/sidebar-widgets/all (public/authenticated)","PUT /api/sidebar-widgets/bulk authenticated","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"gallery","requests":["GET /api/gallery","GET /api/gallery/all (public/authenticated)","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"documents","requests":["GET /api/documents?page=1&limit=2","GET /api/documents/:id","GET /api/documents/download/:id","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"faq","requests":["GET /api/faq","GET /api/faq/all (public/authenticated)","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"banners","requests":["GET /api/banners","GET /api/banners/all (public/authenticated)","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"complaints","requests":["POST /api/complaints validation/success","GET /api/complaints (public/authenticated)","GET /api/complaints/:id authenticated","PUT /api/complaints/:id authenticated","DELETE /api/complaints/:id authenticated"]},
    {"route":"analytics","requests":["POST /api/analytics/track","GET /api/analytics (public/authenticated)"]},
    {"route":"surveys","requests":["GET /api/surveys/config","PUT /api/surveys/config authenticated","POST /api/surveys/submit","GET /api/surveys (public/authenticated)"]},
    {"route":"search","requests":["GET /api/search?q=..."]},
    {"route":"menus","requests":["GET /api/menus","GET /api/menus/all (public/authenticated)","PUT /api/menus/bulk authenticated","POST+PUT+DELETE successful authenticated CRUD for every mutable handler domain"]},
    {"route":"seed","operational":true,"excluded":true,"reason":"Public operational seed route is intentionally never invoked; fixtures are inserted directly into the validated disposable database.","requests":[]},
    {"route":"catch-all","requests":["GET /api/not-a-route","OPTIONS /api/news"]}
  ],
  "normalization": {
    "ignoredKeys": ["_id"],
    "uuidKeys": ["id", "fileName", "url"],
    "timestampKeys": ["createdAt", "updatedAt"],
    "jwtKeys": ["token", "iat", "exp"]
  },
  "stableExpectations": {
    "jsonContentType": "application/json",
    "paginationKeys": ["items", "total", "page", "totalPages"],
    "unauthorized": {"status": 401, "body": {"error": "Unauthorized"}},
    "notFoundRoute": {"status": 404, "body": {"error": "Route tidak ditemukan"}},
    "deleteBody": {"message": "Berhasil dihapus"},
    "cors": {
      "status": 200,
      "access-control-allow-origin": "*",
      "access-control-allow-methods": "GET, POST, PUT, DELETE, OPTIONS, PATCH",
      "access-control-allow-headers": "Content-Type, Authorization"
    }
  }
}
