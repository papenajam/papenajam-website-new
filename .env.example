# --------------------------------------------------------------------------
# Example environment file for the MongoDB -> PostgreSQL + Prisma migration.
# --------------------------------------------------------------------------
#
# This file is TRACKED in Git and contains ONLY placeholders. Copy it to
# `.env` (which is gitignored) and replace every placeholder with a real
# value for your LOCAL/TEST environment. NEVER commit a real secret.
#
#   cp .env.example .env
#
# Scope: LOCAL AND TEST ONLY. Production secrets are provisioned out of band
# and MUST NOT live in this repository.

# ==========================================================================
# PostgreSQL (local/test target database)
# ==========================================================================
#
# These map to the container defined in `compose.db.yml`. The dev and test
# databases are intentionally SEPARATE so tests can be reset without
# disturbing development data. See `docs/database-local-setup.md`.
#
# Driver: `postgresql://` is the Prisma v7 + postgres adapter scheme.

# Application database name (development). Must match POSTGRES_DEV_DB in
# compose.db.yml.
DB_NAME=pa_penajam_dev

# Connection strings. Use 127.0.0.1 (not localhost) so the driver resolves
# IPv4 directly to the published container port.
DATABASE_URL_DEV=postgresql://papenajam:CHANGE_ME@127.0.0.1:5432/pa_penajam_dev?schema=public
DATABASE_URL_TEST=postgresql://papenajam:CHANGE_ME@127.0.0.1:5432/pa_penajam_test?schema=public

# Default connection used by Prisma when no override is supplied. Point this
# at the DEV database for normal local work; CI/tests override it with
# DATABASE_URL_TEST.
DATABASE_URL=postgresql://papenajam:CHANGE_ME@127.0.0.1:5432/pa_penajam_dev?schema=public

# Local container superuser password and app role credentials. PLACEHOLDERS.
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_APP_USER=papenajam
POSTGRES_APP_PASSWORD=CHANGE_ME
POSTGRES_DEV_DB=pa_penajam_dev
POSTGRES_TEST_DB=pa_penajam_test

# ==========================================================================
# MongoDB source (migration-only tooling)
# ==========================================================================
#
# Used by the read-only profiler and the importer (scripts/migration/*) to
# read the source data during the migration. The Next.js application does
# NOT read this once the PostgreSQL cut-over is complete.
#
# IMPORTANT: never point this at a production MongoDB without explicit
# read-only credentials (a server-side role) and an approved maintenance
# window. Read-only access must come from the MongoDB user's granted role,
# NOT from a URI query option — the modern driver rejects unknown options
# like `?readOnly=true`, and such options do not confer privileges anyway.
MONGO_URL=mongodb://CHANGE_ME:CHANGE_ME@127.0.0.1:27017/pa_penajam_source

# Optional: source database name override used by the profiler.
MONGO_DB_NAME=pa_penajam_source

# ==========================================================================
# Application secrets
# ==========================================================================
#
# JWT signing secret. Generate a strong value for local work, e.g.:
#   openssl rand -base64 48
# NEVER reuse a production secret locally, and NEVER commit a real one.
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# ==========================================================================
# File uploads
# ==========================================================================
#
# Absolute or repo-relative path where uploaded media is stored. The local
# dev server writes here; the path is passed to the upload route handlers.
UPLOAD_PATH=./public/uploads

# ==========================================================================
# Seed accounts (local/test ONLY — used by `prisma db seed`)
# ==========================================================================
#
# Passwords for the three demo accounts created by prisma/seed.mjs.
# If unset, the seed script generates a cryptographically random password
# and prints it ONCE to stdout. NEVER commit real production passwords.
# Rotate any password that ever appeared in the old public /api/seed handler.
SEED_ADMIN_PASSWORD=
SEED_STAFF_PASSWORD=
SEED_EDITOR_PASSWORD=
